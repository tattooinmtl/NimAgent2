# User home: real settings (API keys), sessions, memory — never committed
agent/

# Secrets
.env
*.pem
*.key

# Vendored binaries (fetched by the installer, not committed)
vendor/
llama/
*.gguf

# ML artifacts (regenerated by router/train.py)
router/model.pkl
router/.venv/

# Build / packaging output
dist/
node_modules/

# Editor / OS noise
.vscode/
.idea/
Thumbs.db
.DS_Store

# Local working notes stay out of the repo, but shipped reference docs are
# whitelisted (skills/extend-nimagent points users at docs/EXTENDING.md).
docs/*
!docs/EXTENDING.md
!docs/TESTED_FEATURES.md
!docs/LIVE_TEST_*.md
!docs/SECURITY_AUDIT_*.md
!docs/PLAN_*.md
*.bak
*.bak?
*.backup
