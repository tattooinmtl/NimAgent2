router/model.pkl
router/.venv/

# Build / packaging output
dist/
node_modules/

# Editor / OS noise
.vscode/
.idea/
Thumbs.db
.DS_Store

# Local working notes (no markdown in repo except README.md)
docs/
*.bak
*.bak?
*.backup
