{
  "name": "nimagent2",
  "version": "2.1.0",
  "private": true,
  "type": "module",
  "description": "NimAgent V2 - a from-scratch terminal coding agent for OpenAI-compatible providers (Vice Summer Edition 2026)",
  "author": "Erik Boivin <erik.boivin@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/tattooinmtl/NimAgent2#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tattooinmtl/NimAgent2.git"
  },
  "bugs": {
    "url": "https://github.com/tattooinmtl/NimAgent2/issues"
  },
  "bin": {
    "nim2": "./bin/nimagent.mjs"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node ./bin/nimagent.mjs",
    "test": "node ./tests/run-all.mjs",
    "setup": "node ./scripts/setup.mjs",
    "setup:router": "node ./scripts/setup.mjs --with-router",
    "zip:source": "git archive --worktree-attributes --format=zip --output dist/nimagent-source.zip HEAD",
    "install:check": "powershell -NoProfile -ExecutionPolicy Bypass -File ./install/install.ps1 -SkipRepoUpdate",
    "install:update": "powershell -NoProfile -ExecutionPolicy Bypass -File ./install/install.ps1 -AutoUpdate"
  }
}
